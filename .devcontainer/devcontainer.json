{
  "name": "PKCS11 Course",
  "dockerComposeFile": "../lab/docker-compose.yml",
  "service": "pkcs11-dev",
  "workspaceFolder": "/workspace",
  "remoteEnv": {
    "GRADLE_USER_HOME": "/workspace/.gradle",
    "GOROOT": "/usr/local/go",
    "PATH": "/usr/local/go/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "fwcd.kotlin",
        "ms-dotnettools.csharp",
        "vscjava.vscode-java-pack",
        "redhat.vscode-yaml"
      ]
    }
  }
}
